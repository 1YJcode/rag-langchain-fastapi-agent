# 阿里云通义千问 (Agent LLM)
ALIYUN_ACCESS_KEY_SECRET=your_dashscope_api_key
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 数据库 (用户服务 MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=news_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
FASTAPI_SECRET_KEY=your_secret_key_change_this
FASTAPI_ALGORITHM=HS256

# 用户服务地址 (Agent 验证 Token 用)
USER_SERVICE_URL=http://localhost:8000

# 重排序模型路径
RERANKER_MODEL_PATH=D:\Hugging_Face\models\Qwen3-Reranker-0.6B

# 通义千问 API Key (与 ALIYUN_ACCESS_KEY_SECRET 相同)
CHAT_API_KEY=your_dashscope_api_key
